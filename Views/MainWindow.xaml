<Window x:Class="SI360.GateRunner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SI360.GateRunner.ViewModels"
        xmlns:views="clr-namespace:SI360.GateRunner.Views"
        xmlns:sv="clr-namespace:SI360.GateRunner.Services"
        Title="SI360 Pre-Deployment Gate Runner"
        Icon="pack://application:,,,/SI360.GateRunner;component/Resources/gaterunner.ico"
        Width="1480" Height="920"
        Style="{StaticResource AppWindowStyle}"
        KeyboardNavigation.TabNavigation="Cycle"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <!-- #6 Keyboard shortcuts -->
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RunGatesCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
        <KeyBinding Modifiers="Control" Key="R" Command="{Binding OpenReportCommand}"/>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding ToggleThemeCommand}"/>
        <KeyBinding Modifiers="Control" Key="D1" Command="{Binding SwitchTabCommand}" CommandParameter="0"/>
        <KeyBinding Modifiers="Control" Key="D2" Command="{Binding SwitchTabCommand}" CommandParameter="1"/>
        <KeyBinding Modifiers="Control" Key="D3" Command="{Binding SwitchTabCommand}" CommandParameter="2"/>
        <KeyBinding Modifiers="Control" Key="D4" Command="{Binding SwitchTabCommand}" CommandParameter="3"/>
        <KeyBinding Modifiers="Control+Shift" Key="R" Command="{Binding ToggleShowRedCommand}"/>
        <KeyBinding Modifiers="Control+Shift" Key="Y" Command="{Binding ToggleShowYellowCommand}"/>
        <KeyBinding Modifiers="Control+Shift" Key="G" Command="{Binding ToggleShowGreenCommand}"/>
        <KeyBinding Modifiers="Control+Shift" Key="P" Command="{Binding ToggleShowPendingCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="20,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <!-- #7 Grouped action cluster -->
                <Border DockPanel.Dock="Left"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="_Run Gates  (F5)"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="220"
                                Command="{Binding RunGatesCommand}"
                                AutomationProperties.Name="Run all gates"
                                AutomationProperties.AutomationId="RunGatesButton"/>
                        <Button Content="_Cancel  (Esc)"
                                Margin="4,0,0,0"
                                MinWidth="180"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelCommand}"
                                AutomationProperties.Name="Cancel current run"
                                AutomationProperties.AutomationId="CancelButton"/>
                        <Button Content="_Open Report  (Ctrl+R)"
                                Margin="4,0,0,0"
                                MinWidth="240"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenReportCommand}"
                                AutomationProperties.Name="Open last report"
                                AutomationProperties.AutomationId="OpenReportButton"/>
                    </StackPanel>
                </Border>
                <Button DockPanel.Dock="Right"
                        Content="{Binding ThemeToggleText}"
                        Margin="14,0,0,0"
                        MinWidth="120"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Toggle theme (Ctrl+T)"
                        AutomationProperties.Name="Toggle theme"/>
                <Button DockPanel.Dock="Right"
                        Content="_Settings"
                        Margin="14,0,0,0"
                        MinWidth="130"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="Configure paths and timeouts"
                        AutomationProperties.Name="Open settings"
                        AutomationProperties.AutomationId="SettingsButton"/>
                <StackPanel Orientation="Vertical" Margin="28,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" FontSize="13" TextTrimming="CharacterEllipsis">
                            <Run Text="Solution: "/>
                            <Run Text="{Binding SolutionPath, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding EtaText}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="13" Margin="16,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding PreviousRunText}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding ScoreDeltaText}" Margin="10,0,0,0" FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScoreDelta, Converter={x:Static sv:PositiveConverter.Instance}}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreDelta, Converter={x:Static sv:NegativeConverter.Instance}}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="{Binding SettingsWarningText}"
                               FontSize="12"
                               Foreground="{DynamicResource DangerRedBrush}"
                               TextWrapping="Wrap"
                               AutomationProperties.Name="Settings warning">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSettingsWarnings}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CatalogWarningText}"
                               FontSize="12"
                               Foreground="{DynamicResource WarningAmberBrush}"
                               TextWrapping="Wrap"
                               AutomationProperties.Name="Catalog warning">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCatalogWarnings}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Gate list + filter chips -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Gates" FontSize="18" FontWeight="Bold" Margin="16,12,0,4"/>
                    <!-- Chips - 2x2 rectangular, with counts + shortcuts -->
                    <UniformGrid DockPanel.Dock="Top" Margin="16,4,12,8" Rows="2" Columns="2">
                        <ToggleButton Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding ShowRed}" Content="{Binding RedChipLabel}" ToolTip="Show red/error gates (Ctrl+Shift+R)"/>
                        <ToggleButton Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding ShowYellow}" Content="{Binding YellowChipLabel}" ToolTip="Show yellow gates (Ctrl+Shift+Y)"/>
                        <ToggleButton Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding ShowGreen}" Content="{Binding GreenChipLabel}" ToolTip="Show green gates (Ctrl+Shift+G)"/>
                        <ToggleButton Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding ShowPending}" Content="{Binding PendingChipLabel}" ToolTip="Show pending gates (Ctrl+Shift+P)"/>
                    </UniformGrid>
                    <ProgressBar DockPanel.Dock="Top" Height="6" Margin="16,0,16,8"
                                 Minimum="0" Maximum="{Binding TotalGates}" Value="{Binding CompletedGates, Mode=OneWay}"/>
                    <TextBlock DockPanel.Dock="Bottom" Margin="16,4,16,10"
                               FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="Double-click a gate to re-run only it."/>
                    <ListBox ItemsSource="{Binding GatesView}" SelectedItem="{Binding SelectedGate}"
                             HorizontalContentAlignment="Stretch" BorderThickness="0"
                             sv:ListBoxBehavior.DoubleClickCommand="{Binding RerunGateCommand}"
                             AutomationProperties.Name="Gate list">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GateRunViewModel}">
                                <Border Padding="12,8" ToolTip="{Binding Tooltip}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource MutedForegroundBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Fill" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Green">
                                                            <Setter Property="Fill" Value="{DynamicResource SuccessGreenBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Yellow">
                                                            <Setter Property="Fill" Value="{DynamicResource WarningAmberBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Red">
                                                            <Setter Property="Fill" Value="{DynamicResource DangerRedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Fill" Value="{DynamicResource DangerRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding DurationMs, StringFormat={}{0:N0}ms}" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="280"/>
                </Grid.RowDefinitions>

                <TabControl x:Name="MainTabs" Grid.Row="0" Background="Transparent" BorderThickness="0">
                    <TabItem Header="Gate Detail">
                        <views:GateDetailView DataContext="{Binding SelectedGate}"/>
                    </TabItem>
                    <TabItem Header="Failures">
                        <views:FailureInventoryView/>
                    </TabItem>
                    <TabItem Header="Scorecard">
                        <views:ScorecardView DataContext="{Binding Scorecard}"/>
                    </TabItem>
                    <TabItem Header="Build Errors">
                        <DataGrid ItemsSource="{Binding BuildErrors}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="*"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="80"/>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>

                <!-- Live log with auto-scroll -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="dotnet output" FontSize="14" FontWeight="SemiBold" Margin="12,8,0,4"/>
                        <TextBox Text="{Binding LogTail, Mode=OneWay}"
                                 IsReadOnly="True"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 sv:TextBoxBehavior.AutoScrollToEnd="True"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer scorecard tile -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" DataContext="{Binding Scorecard}">
                    <TextBlock Text="Overall:" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OverallScore, StringFormat={}{0:0.0}}" FontSize="24" FontWeight="Bold" Margin="8,0,16,0"/>
                    <TextBlock Text="Grade:" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Grade}" FontSize="24" FontWeight="Bold" Margin="8,0,16,0"/>
                    <TextBlock Text="Scenario:" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ScenarioScore, StringFormat={}{0:0.0}}" FontSize="18" Margin="8,0,16,0"/>
                    <TextBlock Text="Probabilistic:" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ProbabilisticScore, StringFormat={}{0:0.0}}" FontSize="18" Margin="8,0,16,0"/>
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="8" Padding="22,10" Margin="16,0,8,0" MinWidth="140" DataContext="{Binding Scorecard}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource DangerRedBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Decision}" Value="Go">
                                    <Setter Property="Background" Value="{DynamicResource SuccessGreenBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Decision}" Value="Hold">
                                    <Setter Property="Background" Value="{DynamicResource WarningAmberBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DecisionText}" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
